description="Qdrant Vector Search Engine"
command="/usr/bin/qdrant"
command_args="--config-path /etc/qdrant/config.yaml"
command_background=true
pidfile="/run/${RC_SVCNAME}.pid"
directory="/var/lib/qdrant"

depend() {
	need net
	after net
}
