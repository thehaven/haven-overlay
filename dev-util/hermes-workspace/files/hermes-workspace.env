# Hermes Workspace — default configuration
#
# This file is sourced by the hermes-workspace systemd unit
# (EnvironmentFile=). Uncomment and set values as needed.
#
# Full env-var reference:
# https://github.com/outsourc-e/hermes-workspace/blob/v2.3.0/.env.example

# ── Server ──────────────────────────────────────────────────────
# Listen port (default: 3000)
#PORT=3000
# Bind address (default: 127.0.0.1; set 0.0.0.0 for remote access)
#HOST=127.0.0.1
# Node environment
#NODE_ENV=production

# ── Hermes Agent backend (required for chat/orchestration) ──────
# URL of a Hermes Agent gateway or OpenAI-compatible server
#HERMES_API_URL=http://127.0.0.1:8642
# Bearer token for an authenticated gateway
#HERMES_API_TOKEN=
# Dashboard plugin URL
#HERMES_DASHBOARD_URL=http://127.0.0.1:9119
#HERMES_DASHBOARD_TOKEN=

# ── Security (required for non-loopback HOST) ───────────────────
# Workspace session password — mandatory if HOST != 127.0.0.1
#HERMES_PASSWORD=
# Bypass the fail-closed startup guard (NOT recommended)
#HERMES_ALLOW_INSECURE_REMOTE=0
# Cookie Secure flag (set 0 for plain-HTTP LAN)
#COOKIE_SECURE=1
# Trust proxy-forwarded headers (behind reverse proxy)
#TRUST_PROXY=0

# ── LLM provider keys (read by Hermes Agent gateway, not workspace)
# Pass through to the gateway service. Pick one or more.
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#GOOGLE_API_KEY=

# ── SSE stream timeouts ────────────────────────────────────────
#STREAM_ACCEPTED_TIMEOUT_MS=120000
#STREAM_HANDOFF_TIMEOUT_MS=300000
