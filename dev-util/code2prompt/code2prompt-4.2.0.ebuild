RUST_MIN_VER="1.85.0"

inherit cargo

DESCRIPTION="A CLI tool to convert codebases into single LLM prompts"
HOMEPAGE="https://github.com/mufeedvh/code2prompt"
SRC_URI="https://github.com/mufeedvh/code2prompt/archive/refs/tags/v${PV}.tar.gz -> ${P}.tar.gz
	${CARGO_CRATE_URIS}"

LICENSE="MIT"
# Dependent crate licenses
LICENSE+="
	Apache-2.0 Apache-2.0-with-LLVM-exceptions BSD Boost-1.0 MIT MPL-2.0
	Unicode-3.0 ZLIB
"
SLOT="0"
KEYWORDS="~amd64"

RDEPEND="
	dev-libs/openssl:0=
"
DEPEND="${RDEPEND}"
BDEPEND="
	virtual/pkgconfig
"

src_compile() {
	# We want to build the code2prompt package specifically
	cargo_src_compile --package code2prompt
}

src_install() {
	# Install from the specific crate directory
	cargo_src_install --path crates/code2prompt
	einstalldocs
}
