[Unit]
Description=LiteLLM Proxy - Unified LLM API Gateway
Documentation=https://docs.litellm.ai
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/litellm/bin/litellm --config /etc/litellm/config.yaml --host 0.0.0.0 --port 4000
WorkingDirectory=/var/lib/litellm
Restart=on-failure
RestartSec=5

NoNewPrivileges=yes
ProtectHome=yes
ReadWritePaths=/var/lib/litellm
ReadWritePaths=/var/log/litellm
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
