# User and group the daemon runs as.
SPEACHES_USER="speaches"
SPEACHES_GROUP="speaches"

# uvicorn bind interface and port.
SPEACHES_HOST="0.0.0.0"
SPEACHES_PORT="8000"

# Number of worker processes.
SPEACHES_WORKERS="1"
