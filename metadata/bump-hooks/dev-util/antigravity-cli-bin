#!/usr/bin/env python3
import json
import re
import sys
import urllib.request

def main():
    if len(sys.argv) < 2:
        sys.exit(1)
    new_version = sys.argv[1]
    
    # Fetch manifest
    url = "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/linux_amd64.json"
    try:
        with urllib.request.urlopen(url) as resp:
            data = json.load(resp)
    except Exception:
        sys.exit(1)
    
    # We should only return something if the version matches or if we want to force it
    # But for a hook, we just want to provide the new BASE_URI
    
    # Extract base URI
    match = re.match(r"(https://.*/antigravity-cli/[^/]+)/linux-x64", data["url"])
    if not match:
        sys.exit(1)
        
    base_uri = match.group(1)
    print(f"BASE_URI={base_uri}")

if __name__ == "__main__":
    main()
